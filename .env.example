# ==============================================================================
# QualiAI Configuration Environment Variables
# Copy this file to '.env' and fill in values to toggle Production Mode.
# Leaving these empty automatically falls back to Demo Mode (SQLite, Mock AI, Logs).
# ==============================================================================

# Backend running port (Defaults to 5000)
PORT=5000

# JSON Web Token Cryptographic Signing Key
JWT_SECRET=quali_ai_secret_key_123456

# Database Provider (Defaults to sqlite if DATABASE_URL is missing)
# For Postgres, set the link below. Example: postgresql://username:password@localhost:5432/qualiai
DATABASE_URL=

# AI Model Provider: OpenRouter
# Register and fetch keys at https://openrouter.ai/
OPENROUTER_API_KEY=

# Telegram Notification Channel
# Get Bot token from @BotFather and Chat ID from @userinfobot on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
